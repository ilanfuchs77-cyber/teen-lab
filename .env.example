# Set one or more AI provider keys. The app works with zero keys (returns
# rich demo data); add a key to make that provider answer for real.
# The user picks which provider to use from the in-app AI selector.

GEMINI_API_KEY=your_gemini_api_key_here      # Google Gemini
OPENAI_API_KEY=your_openai_api_key_here      # OpenAI GPT
ANTHROPIC_API_KEY=your_anthropic_api_key_here # Anthropic Claude

PORT=3001
